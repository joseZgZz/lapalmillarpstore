# =============================================
# DISCORD ROLEPLAY STORE - .gitignore
# =============================================

# Node modules (no se sube, se instala con npm install)
node_modules/
*/node_modules/

# Variables de entorno (Ocultando de nuevo por seguridad)
.env
.env.local
.env.production
.env.*.local
**/.env

# Archivos de build
dist/
build/
.next/

# Logs
*.log
npm-debug.log*

# Cache
.vite/
.cache/

# Sistema operativo
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
